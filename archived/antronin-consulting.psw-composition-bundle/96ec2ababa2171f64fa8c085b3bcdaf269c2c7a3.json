{
    "manifests": {
        "antronin-consulting/psw-composition-bundle": {
            "manifest": {
                "bundles": {
                    "Antronin-Consulting\\PswCompositionBundle\\PswCompositionBundle": [
                        "all"
                    ]
                },
                "copy-from-recipe": {
                    "config/packages/psw_composition.yaml": "%CONFIG_DIR%/packages/psw_composition.yaml"
                },
                "composer-scripts": {
                    "cache:clear": "symfony-cmd"
                }
            },
            "files": {
                "config/packages/psw_composition.yaml": {
                    "contents": [
                        "#",
                        "# File: \\config\\packages\\psw_composition.yaml",
                        "# Author: Peter Nagy <peter@antronin.consulting>",
                        "# -----",
                        "psw_composition:",
                        "        length:",
                        "            min: '%env(int:PASSWORD_MINLENGTH)%'",
                        "            max: '%env(int:PASSWORD_MAXLENGTH)%'",
                        "        contents:",
                        "            uppercase:",
                        "                min: '%env(int:PASSWORD_MINUPPERCASE)%'",
                        "                pattern: '%env(PASSWORD_UPPERCASE_PATTERN)%'",
                        "            lowercase:",
                        "                min: '%env(int:PASSWORD_MINLOWERCASE)%'",
                        "                pattern: '%env(PASSWORD_LOWERCASE_PATTERN)%'",
                        "            number:",
                        "                min: '%env(int:PASSWORD_MINNUMBER)%'",
                        "                pattern: '%env(PASSWORD_NUMBER_PATTERN)%'",
                        "            special:",
                        "                min: '%env(int:PASSWORD_MINSPECIAL)%'",
                        "                pattern: '%env(PASSWORD_SPECIALS_PATTERN)%'",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "96ec2ababa2171f64fa8c085b3bcdaf269c2c7a3"
        }
    }
}
