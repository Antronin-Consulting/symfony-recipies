{
    "manifests": {
        "antronin-consulting/psw-expiration-bundle": {
            "manifest": {
                "bundles": {
                    "AntroninConsulting\\PswExpirationBundle\\PswExpirationBundle": [
                        "all"
                    ]
                },
                "copy-from-recipe": {
                    "config/packages/psw_expiration.yaml": "%CONFIG_DIR%/packages/psw_expiration.yaml"
                },
                "env": {
                    "PASSWORD_LIFETIME": 90,
                    "PASSWORD_WARNING_THRESHOLD": 7,
                    "PASSWORD_EXPIRATION_UNIT": "days"
                },
                "composer-scripts": {
                    "cache:clear": "symfony-cmd"
                },
                "gitignore": [
                    ".env"
                ]
            },
            "files": {
                "config/packages/psw_expiration.yaml": {
                    "contents": [
                        "#",
                        "# File: \\config\\packages\\psw_expiration.yaml",
                        "# Author: Peter Nagy <peter@antronin.consulting>",
                        "# -----",
                        "psw_expiration:",
                        "    lifetime: '%env(int:PASSWORD_LIFETIME)%'",
                        "    warning_threshold: '%env(int:PASSWORD_WARNING_THRESHOLD)%'",
                        "    unit: '%env(PASSWORD_EXPIRATION_UNIT)%'",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "dd4acfc4d423873224ef6ab96a504e83ca7cf701"
        }
    }
}
